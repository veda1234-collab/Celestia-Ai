# ─────────────────────────────────────────────────────────────
# Vedastra environment. Copy to `.env.local`.
# The app runs with ZERO config (mock AI + bundled cities + no auth).
# Fill only what you want to enable.
# ─────────────────────────────────────────────────────────────

# ── AI Astrologer ──
# Provider: openai | claude | mock. Auto-detects from whichever key is set.
# Generic names (LLM_*) and provider-specific names are both accepted.
LLM_PROVIDER=openai
LLM_API_KEY=
# Or, provider-specific:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Geocoding / birthplace autocomplete ──
GEOCODER=local            # local (bundled) | google | mapbox
GOOGLE_PLACES_API_KEY=
MAPBOX_TOKEN=

# ── Auth + persistence (optional) ──
# Set DATABASE_URL to enable accounts + saved charts. SQLite works out of the box;
# for Postgres, change the datasource provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"
JWT_SECRET=change-me-to-a-long-random-string

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
